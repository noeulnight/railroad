generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TrainDirection {
  UP
  DOWN
}

enum TrainEventType {
  CREATED
  UPDATED
  REMOVED
}

model Station {
  id        String   @id @default(cuid())
  name      String   @unique
  grade     Int?
  latitude  Float?
  longitude Float?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stations")
}

model TrainSnapshotSample {
  id                   String         @id @default(cuid())
  sampledAt            DateTime       @map("sampled_at")
  trainId              String         @map("train_id")
  type                 String
  direction            TrainDirection
  delayMinutes         Int            @map("delay_minutes")
  currentStationName   String?        @map("current_station_name")
  nextStationName      String?        @map("next_station_name")
  departureStationName String?        @map("departure_station_name")
  arrivalStationName   String?        @map("arrival_station_name")
  latitude             Float
  longitude            Float

  @@index([sampledAt])
  @@index([trainId, sampledAt(sort: Desc)])
  @@map("train_snapshot_samples")
}

model TrainEvent {
  id                 String          @id @default(cuid())
  occurredAt         DateTime        @map("occurred_at")
  eventType          TrainEventType  @map("event_type")
  trainId            String          @map("train_id")
  type               String?
  direction          TrainDirection?
  delayMinutes       Int?            @map("delay_minutes")
  previousLatitude   Float?          @map("previous_latitude")
  previousLongitude  Float?          @map("previous_longitude")
  latitude           Float?
  longitude          Float?
  currentStationName String?         @map("current_station_name")
  nextStationName    String?         @map("next_station_name")

  @@index([occurredAt])
  @@index([trainId, occurredAt(sort: Desc)])
  @@map("train_events")
}

model TrainStatsHourly {
  id                String   @id @default(cuid())
  bucketStart       DateTime @unique @map("bucket_start")
  activeTrainCount  Int      @default(0) @map("active_train_count")
  delayedTrainCount Int      @default(0) @map("delayed_train_count")
  avgDelay          Float    @default(0) @map("avg_delay")
  maxDelay          Int      @default(0) @map("max_delay")
  createdCount      Int      @default(0) @map("created_count")
  removedCount      Int      @default(0) @map("removed_count")

  @@map("train_stats_hourly")
}
